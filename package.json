{
  "name": "@nodebug/axios",
  "version": "2.0.2",
  "author": {
    "name": "Node Bug",
    "email": "nodebug@outlook.com"
  },
  "bugs": {
    "url": "https://github.com/node-bug/axios/issues"
  },
  "dependencies": {
    "@nodebug/config": "^2.1.1",
    "@nodebug/logger": "^1.1.2",
    "axios": "^1.6.0",
    "http-cookie-agent": "^7.0.3",
    "tough-cookie": "^6.0.1"
  },
  "description": "Boilerplate for Node.js projects with axios and cookie support",
  "homepage": "https://github.com/node-bug/axios#readme",
  "keywords": [
    "node",
    "npm",
    "axios",
    "cookie",
    "boilerplate"
